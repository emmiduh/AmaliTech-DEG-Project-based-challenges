# WatchTower observability stack — copy to `.env` and adjust.
# Docker Compose reads this file automatically for variable substitution in `docker-compose.yml`.

# ---------------------------------------------------------------------------
# Published host ports (format HOST_PORT:CONTAINER_PORT uses the left side)
# ---------------------------------------------------------------------------
ORDER_SERVICE_HOST_PORT=3001
TRACKING_SERVICE_HOST_PORT=3002
NOTIFICATION_SERVICE_HOST_PORT=3003

PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3000

# Optional: expose Blackbox UI for debugging HTTP probes (set to empty in .env to skip publishing)
BLACKBOX_HOST_PORT=9115

# ---------------------------------------------------------------------------
# Container-internal ports (must match what each Node process listens on).
# If you change these, you MUST update prometheus/prometheus.yml scrape targets
# (and Blackbox probe URLs) to match — Compose cannot rewrite those files automatically.
# ---------------------------------------------------------------------------
ORDER_SERVICE_INTERNAL_PORT=3001
TRACKING_SERVICE_INTERNAL_PORT=3002
NOTIFICATION_SERVICE_INTERNAL_PORT=3003

# ---------------------------------------------------------------------------
# Prometheus / Grafana
# ---------------------------------------------------------------------------
PROMETHEUS_INTERNAL_PORT=9090
GRAFANA_INTERNAL_PORT=3000

# Scrape interval (informational for operators; Prometheus config uses the same value)
SCRAPE_INTERVAL=15s

# Grafana admin user (GF_* variables are consumed by the official Grafana image)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_before_first_login

# Grafana server root URL (useful behind reverse proxies; fine for local Docker)
GF_SERVER_ROOT_URL=http://localhost:3000
